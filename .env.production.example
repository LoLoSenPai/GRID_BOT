NODE_ENV=production
APP_URL=https://grid.example.com

POSTGRES_DB=grid_bot
POSTGRES_USER=grid_bot
POSTGRES_PASSWORD=replace-with-a-strong-password
DATABASE_URL=postgresql://grid_bot:replace-with-a-strong-password@postgres:5432/grid_bot

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
SESSION_SECRET=replace-with-a-long-random-string

DISCORD_WEBHOOK_URL=
LIVE_TRADING_ENABLED=false

DEFAULT_CLUSTER=mainnet-beta
RPC_HTTP_URL=https://mainnet.helius-rpc.com/?api-key=replace-me
RPC_WS_URL=wss://mainnet.helius-rpc.com/?api-key=replace-me

JUPITER_API_KEY=
PYTH_HERMES_BASE_URL=https://hermes.pyth.network
PYTH_HISTORY_BASE_URL=https://pyth.dourolabs.app/v1

BOT_TICK_INTERVAL_MS=2000
PRICE_STALE_AFTER_MS=10000

# Host path used by docker compose to mount the wallet file into the containers.
EXECUTION_WALLET_HOST_PATH=/opt/grid-bot/wallets/execution-wallet.json

# Path visible from inside the containers. Keep this value unless you change docker-compose.prod.yml.
EXECUTION_WALLET_SECRET_KEY_PATH=/run/secrets/execution-wallet.json
