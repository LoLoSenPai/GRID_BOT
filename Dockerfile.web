FROM node:22-bookworm-slim AS base
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable

ARG NODE_ENV=production
ARG APP_URL
ARG DATABASE_URL
ARG ADMIN_USERNAME
ARG ADMIN_PASSWORD
ARG SESSION_SECRET
ARG DISCORD_WEBHOOK_URL
ARG LIVE_TRADING_ENABLED
ARG DEFAULT_CLUSTER
ARG RPC_HTTP_URL
ARG RPC_WS_URL
ARG EXECUTION_WALLET_SECRET_KEY_PATH
ARG JUPITER_API_KEY
ARG PYTH_HERMES_BASE_URL
ARG PYTH_HISTORY_BASE_URL
ARG BOT_TICK_INTERVAL_MS
ARG PRICE_STALE_AFTER_MS

ENV NODE_ENV=$NODE_ENV
ENV APP_URL=$APP_URL
ENV DATABASE_URL=$DATABASE_URL
ENV ADMIN_USERNAME=$ADMIN_USERNAME
ENV ADMIN_PASSWORD=$ADMIN_PASSWORD
ENV SESSION_SECRET=$SESSION_SECRET
ENV DISCORD_WEBHOOK_URL=$DISCORD_WEBHOOK_URL
ENV LIVE_TRADING_ENABLED=$LIVE_TRADING_ENABLED
ENV DEFAULT_CLUSTER=$DEFAULT_CLUSTER
ENV RPC_HTTP_URL=$RPC_HTTP_URL
ENV RPC_WS_URL=$RPC_WS_URL
ENV EXECUTION_WALLET_SECRET_KEY_PATH=$EXECUTION_WALLET_SECRET_KEY_PATH
ENV JUPITER_API_KEY=$JUPITER_API_KEY
ENV PYTH_HERMES_BASE_URL=$PYTH_HERMES_BASE_URL
ENV PYTH_HISTORY_BASE_URL=$PYTH_HISTORY_BASE_URL
ENV BOT_TICK_INTERVAL_MS=$BOT_TICK_INTERVAL_MS
ENV PRICE_STALE_AFTER_MS=$PRICE_STALE_AFTER_MS

WORKDIR /app
COPY . .
RUN pnpm install --frozen-lockfile
RUN pnpm db:generate
RUN pnpm --filter @grid-bot/web build

EXPOSE 3000
CMD ["pnpm", "--filter", "@grid-bot/web", "exec", "next", "start", "--hostname", "0.0.0.0", "--port", "3000"]
