FROM node:22-bookworm-slim AS base
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable

WORKDIR /app
COPY . .
RUN pnpm install --frozen-lockfile
RUN pnpm db:generate
RUN pnpm --filter @grid-bot/web build

EXPOSE 3000
CMD ["pnpm", "--filter", "@grid-bot/web", "exec", "next", "start", "--hostname", "0.0.0.0", "--port", "3000"]
